      "ASSERT(rule=\"Primordia veto applies to profile promotion\",pass=true)"
    ],
    "GL_G": [
      "IDX(key=\"MODULE_ARCH_PLUS:M10:3.0.0\")",
      "TAG(ns=\"ORA\",name=\"ARCH_PLUS\")",
      "TAG(ns=\"CODE_POS\",name=\"M10\")",
      "TAG(ns=\"MODE\",name=\"ARCHI_PERSONA_ACTIVATION\")",
      "ROUTE(module=\"ORA_CORE_RAG\",mode=\"ARCH_PLUS_IMPLANT\")"
    ]
  }
