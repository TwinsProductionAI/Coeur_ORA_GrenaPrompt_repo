        "manifest_hash",
        "source_status_for_each_field",
        "no_final_answer_from_registry_entry"
      ]
    },
    "GL": [
      "LIMIT(key=\"code_pos\",rule=\"ARCH_PLUS remains M10\")",
      "LIMIT(key=\"personae\",rule=\"max_active<=4\")",
      "LIMIT(key=\"arc_plus_plus\",rule=\"max_active<=4\")",
      "LIMIT(key=\"no_invention\",rule=\"missing profile data=>SUGGESTION|INCERTAIN\")",
